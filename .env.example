# Supabase project (public-by-design values; safe for client bundles)
PUBLIC_SUPABASE_URL=https://onpxhlufgqmvjckydacp.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Site URL used for sitemap/canonical tags
PUBLIC_SITE_URL=https://pitchglobe.vercel.app

# --- Server-side only (NEVER commit real values, NEVER expose to the client) ---
# football-data.org API key — set as a Supabase Edge Function secret:
#   supabase secrets set FOOTBALL_DATA_API_KEY=...
# Per football-data.org Terms §6.1, developer credentials must not be stored in
# code repositories.
# FOOTBALL_DATA_API_KEY=

# GitHub Packages read token (read:packages scope) so npm can install @q-labs/cobalt.
# Referenced by ~/.npmrc as ${GITHUB_TOKEN}; on Vercel/Netlify set NPM_TOKEN instead.
# GITHUB_TOKEN=
